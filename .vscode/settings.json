{
  "typescript.tsdk": "node_modules/typescript/lib",
  "search.exclude": {
    "**/node_modules": true,
    "**/.expo": true,
    "**/dist": true,
    "**/android": true,
    "**/ios": true
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/.expo": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.expo/**": true,
    "**/dist/**": true
  },
  "typescript.disableAutomaticTypeAcquisition": true,
  "js/ts.implicitProjectConfig.maxNodeModuleJsDepth": 0
}
